{
  "board": { "width": 40, "height": 24 },
  "components": [
    {
      "id": "V1", "kind": "battery", "width": 3, "height": 2,
      "pins": [{ "id": "POS", "x": 2, "y": 1 }, { "id": "NEG", "x": 0, "y": 1 }]
    },
    {
      "id": "U1", "kind": "ic", "width": 4, "height": 5,
      "pins": [
        { "id": "VCC", "x": 2, "y": 0 }, { "id": "GND", "x": 0, "y": 4 },
        { "id": "OUT", "x": 3, "y": 2 }, { "id": "THR", "x": 3, "y": 3 },
        { "id": "CV",  "x": 1, "y": 0 }, { "id": "RST", "x": 0, "y": 0 }
      ]
    },
    {
      "id": "R1", "kind": "resistor", "width": 3, "height": 1,
      "pins": [{ "id": "A", "x": 0, "y": 0 }, { "id": "B", "x": 2, "y": 0 }]
    },
    {
      "id": "R2", "kind": "resistor", "width": 3, "height": 1,
      "pins": [{ "id": "A", "x": 0, "y": 0 }, { "id": "B", "x": 2, "y": 0 }]
    },
    {
      "id": "C1", "kind": "capacitor", "width": 2, "height": 2,
      "pins": [{ "id": "POS", "x": 0, "y": 0 }, { "id": "NEG", "x": 1, "y": 1 }]
    },
    {
      "id": "C2", "kind": "capacitor", "width": 2, "height": 2,
      "pins": [{ "id": "POS", "x": 0, "y": 0 }, { "id": "NEG", "x": 1, "y": 1 }]
    },
    {
      "id": "D1", "kind": "led", "width": 2, "height": 1,
      "pins": [{ "id": "ANODE", "x": 0, "y": 0 }, { "id": "CATHODE", "x": 1, "y": 0 }]
    },
    {
      "id": "R3", "kind": "resistor", "width": 3, "height": 1,
      "pins": [{ "id": "A", "x": 0, "y": 0 }, { "id": "B", "x": 2, "y": 0 }]
    }
  ],
  "nets": [
    { "id": "VCC",  "connections": [{ "component": "V1", "pin": "POS"  }, { "component": "U1",  "pin": "VCC"  }, { "component": "R1", "pin": "A" }] },
    { "id": "RA",   "connections": [{ "component": "R1", "pin": "B"    }, { "component": "R2",  "pin": "A"   }] },
    { "id": "RB",   "connections": [{ "component": "R2", "pin": "B"    }, { "component": "U1",  "pin": "THR" }, { "component": "C1", "pin": "POS" }] },
    { "id": "CV",   "connections": [{ "component": "U1", "pin": "CV"   }, { "component": "C2",  "pin": "POS" }] },
    { "id": "OUT",  "connections": [{ "component": "U1", "pin": "OUT"  }, { "component": "R3",  "pin": "A"   }] },
    { "id": "LED",  "connections": [{ "component": "R3", "pin": "B"    }, { "component": "D1",  "pin": "ANODE" }] },
    { "id": "GND",  "connections": [{ "component": "V1", "pin": "NEG"  }, { "component": "U1",  "pin": "GND"  }, { "component": "C1", "pin": "NEG" }, { "component": "C2", "pin": "NEG" }, { "component": "D1", "pin": "CATHODE" }] }
  ]
}
